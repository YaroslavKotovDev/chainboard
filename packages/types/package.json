{
  "name": "@chainboard/types",
  "version": "0.0.1",
  "private": true,
  "description": "Shared TypeScript types and Zod schemas for ChainBoard",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\""
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@chainboard/config": "workspace:*",
    "typescript": "^5.8.3"
  }
}
