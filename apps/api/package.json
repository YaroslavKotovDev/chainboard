{
  "name": "@chainboard/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "dev:worker": "nest start --watch --entryFile worker",
    "prebuild": "pnpm --dir ../../packages/types run build && pnpm --dir ../../packages/utils run build",
    "build": "tsc -p tsconfig.json",
    "prestart": "pnpm --dir ../../packages/types run build && pnpm --dir ../../packages/utils run build",
    "start": "node dist/apps/api/src/main.js",
    "prestart:worker": "pnpm --dir ../../packages/types run build && pnpm --dir ../../packages/utils run build",
    "start:worker": "node dist/apps/api/src/worker.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@chainboard/types": "workspace:*",
    "@chainboard/utils": "workspace:*",
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.4.22",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.22",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/swagger": "^7.4.2",
    "@prisma/client": "^6.19.3",
    "bullmq": "^5.73.4",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "nestjs-zod": "^5.3.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "siwe": "^3.0.0",
    "viem": "^2.47.12",
    "zod": "^3.25.76"
  },
  "prisma": {
    "seed": "ts-node --project tsconfig.seed.json prisma/seed.ts"
  },
  "devDependencies": {
    "@chainboard/config": "workspace:*",
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.22",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.3",
    "@types/passport-jwt": "^4.0.1",
    "jest": "^30.3.0",
    "prisma": "^6.19.3",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
