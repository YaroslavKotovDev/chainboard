# ============================================================
# ChainBoard API — Environment Variables
# Copy to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# --- Database ---
# PostgreSQL connection string (Neon or local Docker)
DATABASE_URL="postgresql://chainboard:password@localhost:5432/chainboard_dev?schema=public"

# --- Redis ---
# Redis connection string (local Docker or managed)
REDIS_URL="redis://localhost:6379"

# --- Authentication ---
# Long random string — generate with: openssl rand -hex 64
JWT_SECRET="change_me_to_a_long_random_secret"
# Token expiry duration (e.g. 7d, 24h, 3600s)
JWT_EXPIRES_IN="7d"

# --- Sign-in with Ethereum ---
# The domain that will appear in SIWE messages (must match the frontend origin)
SIWE_DOMAIN="localhost"
# Nonce expiry in seconds (default: 300 = 5 minutes)
SIWE_NONCE_EXPIRY_SECONDS="300"

# --- Blockchain ---
# Base Sepolia JSON-RPC endpoint (Alchemy, Infura, or public)
RPC_URL_BASE_SEPOLIA="https://sepolia.base.org"
# Chain ID for the target network
CHAIN_ID="84532"

# --- Server ---
PORT="4000"
NODE_ENV="development"
# Comma-separated allowed CORS origins
CORS_ORIGINS="http://localhost:3000"

# --- Queue ---
# Number of concurrent workers per queue
QUEUE_CONCURRENCY="5"

# --- Sync Worker ---
# Block range per log fetch batch
SYNC_BLOCK_RANGE="500"
# Sync interval in milliseconds
SYNC_INTERVAL_MS="60000"
