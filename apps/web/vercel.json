{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm --filter @chainboard/web build",
  "outputDirectory": ".next",
  "env": {
    "NEXT_PUBLIC_API_URL":                  "@chainboard_api_url",
    "NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID": "@chainboard_wc_project_id",
    "NEXT_PUBLIC_RPC_URL_BASE_SEPOLIA":     "@chainboard_rpc_base_sepolia"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",   "value": "nosniff" },
        { "key": "X-Frame-Options",          "value": "DENY" },
        { "key": "X-XSS-Protection",         "value": "1; mode=block" },
        { "key": "Referrer-Policy",          "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
